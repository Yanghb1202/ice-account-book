/* pages/about/about.wxss */

/* 全局背景与字体设置 */
page {
  background-color: #FAFAFA; /* 干净的浅灰底色，突出白色卡片 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.page-wrap {
  padding: 30rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ================= 顶部品牌区域 ================= */
.brand-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding-top: 40rpx;
}

.logo-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.logo-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FFD54F, #FFB300);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(255, 179, 0, 0.3);
  transform: rotate(-5deg); /* 微微倾斜增加俏皮感 */
}

.app-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.version-pill {
  background: #FFF3E0;
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  color: #F57C00;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  opacity: 0.5;
}

/* ================= 通用卡片样式 ================= */
.card-box {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03); /* 极淡的阴影 */
  border: 1rpx solid rgba(0,0,0,0.02);
}

.card-head {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.head-icon {
  width: 50rpx;
  height: 50rpx;
  background: #FFF8E1;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.head-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* ================= 软件介绍 ================= */
.desc-text {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify; /* 两端对齐更整齐 */
}

/* ================= 核心功能网格 (改为2列布局更大气) ================= */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.feature-item {
  width: calc(50% - 10rpx); /* 两列均分 */
  background: #FAFAFA;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start; /* 左对齐显得更现代 */
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  background: #fff;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 50%;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* ================= 版本信息列表 ================= */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx dashed #eee; /* 虚线分割更轻盈 */
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-row:active {
  opacity: 0.7; /* 点击反馈 */
}

.info-label {
  font-size: 30rpx;
  color: #555;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* ================= 更新日志 ================= */
.update-list {
  padding-left: 10rpx;
}

.update-item {
  position: relative;
  padding-left: 30rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.update-item:last-child {
  margin-bottom: 0;
}

.update-dot {
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 10rpx;
  height: 10rpx;
  background: #FFD54F;
  border-radius: 50%;
}

/* ================= 联系与反馈 ================= */
.contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.contact-row:last-of-type {
  border-bottom: none;
  padding-bottom: 0;
}

.contact-row:active {
  opacity: 0.6;
}

.contact-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.contact-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.contact-arrow {
  color: #ddd;
  font-size: 30rpx;
}

.link-btn {
  margin-top: 40rpx;
  background: linear-gradient(90deg, #FFCA28, #FFB300);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(255, 179, 0, 0.3);
}

.link-btn:active {
  transform: scale(0.98);
}

/* ================= 底部版权 ================= */
.copyright {
  text-align: center;
  padding: 40rpx 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.copyright text:first-child {
  font-size: 24rpx;
  color: #ccc;
}

.copyright-sub {
  font-size: 22rpx;
  color: #e0e0e0;
  font-style: italic;
}

/* ================= 隐私弹窗 ================= */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
}

.privacy-pop {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  z-index: 1000;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.2);
}

.privacy-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.privacy-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.privacy-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.privacy-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.privacy-content text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.privacy-btn {
  background: #333;
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
}