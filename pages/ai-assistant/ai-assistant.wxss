.page-wrap {
  min-height: 100vh;
  background: #fff9e8;
}

.content {
  padding-bottom: 180rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.loading-text {
  font-size: 28rpx;
  color: #9a7b2f;
}

.ai-header {
  background: linear-gradient(135deg, #ffd66e 0%, #ffb22a 100%);
  padding: 40rpx 28rpx;
  display: flex;
  align-items: center;
}

.ai-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 178, 42, 0.3);
}

.ai-info {
  flex: 1;
}

.ai-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 8rpx;
}

.ai-desc {
  font-size: 24rpx;
  color: rgba(90, 62, 10, 0.8);
}

.summary-cards {
  display: flex;
  padding: 0 28rpx;
  margin-top: -40rpx;
  gap: 16rpx;
}

.summary-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 178, 42, 0.15);
}

.summary-card .card-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.summary-card .card-label {
  display: block;
  font-size: 22rpx;
  color: #9a7b2f;
  margin-bottom: 8rpx;
}

.summary-card .card-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}

.summary-card.expense .card-value { color: #ff6b6b; }
.summary-card.income .card-value { color: #52c41a; }

.section {
  background: #fff;
  margin: 24rpx 28rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 178, 42, 0.08);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}

.section-action {
  font-size: 26rpx;
  color: #ffb22a;
  font-weight: 500;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.category-bar-wrap {
  height: 16rpx;
  background: #fff0d0;
  border-radius: 8rpx;
  overflow: hidden;
}

.category-bar {
  height: 100%;
  background: linear-gradient(90deg, #ffd66e 0%, #ffb22a 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.category-info {
  display: flex;
  justify-content: space-between;
}

.category-name {
  font-size: 28rpx;
  color: #5a3e0a;
  font-weight: 500;
}

.category-amount {
  font-size: 26rpx;
  color: #9a7b2f;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff9e8;
  border-radius: 20rpx;
  border-left: 6rpx solid #ffb22a;
}

.suggestion-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 6rpx;
}

.suggestion-desc {
  font-size: 24rpx;
  color: #9a7b2f;
}

.suggestion-arrow {
  font-size: 36rpx;
  color: #ffb22a;
}

.goal-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goal-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff9e8;
  border-radius: 20rpx;
  border-left: 6rpx solid #ffd66e;
}

.goal-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.goal-content {
  flex: 1;
}

.goal-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 6rpx;
}

.goal-desc {
  font-size: 24rpx;
  color: #9a7b2f;
}

.goal-arrow {
  font-size: 36rpx;
  color: #ffb22a;
}

.prediction-card {
  background: #fff9e8;
  border-radius: 20rpx;
  padding: 24rpx;
}

.prediction-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #ffe4a0;
}

.prediction-item:last-of-type {
  border-bottom: none;
}

.prediction-label {
  font-size: 28rpx;
  color: #5a3e0a;
}

.prediction-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
}

.prediction-total {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  margin-top: 10rpx;
  border-top: 2rpx solid #ffd66e;
}

.prediction-total-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.prediction-total-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffb22a;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.detail-content {
  width: 620rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(255, 178, 42, 0.2);
}

.detail-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.detail-desc {
  display: block;
  font-size: 28rpx;
  color: #5a3e0a;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.detail-close {
  background: linear-gradient(135deg, #ffd66e 0%, #ffb22a 100%);
  color: #222;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 44rpx;
}
