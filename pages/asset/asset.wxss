/* pages/asset/asset.wxss */
page {
  background: #fff9e8;
}

.page-wrap {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 90rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff9e8 0%, #fff5dc 100%);
}

.asset-card {
  background: linear-gradient(135deg, #ffd66e, #ffad1f);
  border-radius: 32rpx;
  padding: 36rpx 30rpx;
  color: #5a3e0a;
  box-shadow: 0 10rpx 26rpx rgba(255, 176, 31, 0.25);
  margin-bottom: 24rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-label {
  font-size: 26rpx;
  color: rgba(90,62,10,0.75);
}

.money-row {
  display: flex;
  align-items: flex-end;
  margin-top: 10rpx;
}

.money-symbol {
  font-size: 42rpx;
  font-weight: 700;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

.main-money {
  font-size: 68rpx;
  font-weight: 800;
  line-height: 1;
}

.add-btn {
  background: rgba(255,255,255,0.72);
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  color: #8a5c00;
}

.asset-grid {
  display: flex;
  margin-top: 34rpx;
  background: rgba(255,255,255,0.34);
  border-radius: 22rpx;
  padding: 20rpx 0;
}

.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255,255,255,0.65);
}

.grid-item:last-child {
  border-right: none;
}

.grid-label {
  font-size: 22rpx;
  color: rgba(90,62,10,0.7);
  margin-bottom: 8rpx;
}

.grid-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #5a3e0a;
}

.income {
  color: #2e8b4a;
}

.expense {
  color: #d65a2c;
}

.section-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}

.section-more {
  font-size: 24rpx;
  color: #aaa;
}

.asset-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5efe0;
}

.asset-item:last-child {
  border-bottom: none;
}

.asset-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.asset-info {
  flex: 1;
  min-width: 0;
}

.asset-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.asset-name {
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
}

.type-tag {
  font-size: 21rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.type-tag.asset {
  color: #2e8b4a;
  background: #e9f8ee;
}

.type-tag.debt {
  color: #d65a2c;
  background: #fff0ee;
}

.asset-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #aaa;
}

.asset-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.asset-money {
  font-size: 30rpx;
  font-weight: 700;
}

.delete-text {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
}

.empty-block {
  padding: 80rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #aaa;
  font-size: 27rpx;
}

.empty-icon {
  font-size: 70rpx;
  margin-bottom: 14rpx;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.pop-box {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 84%;
  max-height: 84vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 34rpx;
  box-sizing: border-box;
  z-index: 100;
}

.pop-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 28rpx;
}

.type-tab {
  display: flex;
  background: #f5efe0;
  border-radius: 999rpx;
  padding: 8rpx;
  margin-bottom: 28rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #888;
}

.type-item.active {
  background: #fff;
  color: #222;
  font-weight: 700;
}

.field {
  margin-bottom: 26rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: #222;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.input {
  width: 100%;
  background: #f7f7f7;
  border-radius: 18rpx;
  padding: 24rpx;
  min-height: 86rpx;
  box-sizing: border-box;
  font-size: 29rpx;
}

.icon-row,
.color-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.icon-item {
  width: 60rpx;
  height: 60rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 31rpx;
  border: 4rpx solid transparent;
}

.icon-item.active {
  border-color: #ffc837;
  background: #fff7d9;
}

.color-item {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.color-item.active {
  border-color: #222;
}

.pop-btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  border-radius: 999rpx;
  font-size: 31rpx;
}

.btn-cancel {
  background: #f2f2f2;
  color: #555;
}

.btn-confirm {
  background: linear-gradient(135deg, #ffd66e, #ffad1f);
  color: #fff;
  font-weight: 700;
}
