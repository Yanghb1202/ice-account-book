<!-- pages/billList/billList.wxml -->
<view class="page-wrap">
  <!-- 汇总卡片 -->
  <view class="summary-card">
    <view class="summary-top">
      <view>
        <text class="summary-title">账单明细</text>
        <text class="summary-desc">{{monthValue}} · 共 {{totalCount}} 笔</text>
      </view>
      <view class="add-btn" bindtap="goAddBill">+ 记一笔</view>
    </view>
    <view class="summary-grid">
      <view class="summary-item">
        <text class="sum-label">支出</text>
        <text class="sum-value expense">¥{{totalExpense}}</text>
      </view>
      <view class="summary-item">
        <text class="sum-label">收入</text>
        <text class="sum-value income">¥{{totalIncome}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选区 -->
  <view class="filter-card">
    <view class="type-tab">
      <view class="tab-item {{currentType==-1?'active':''}}" bindtap="switchType" data-type="-1">全部</view>
      <view class="tab-item {{currentType==0?'active':''}}" bindtap="switchType" data-type="0">支出</view>
      <view class="tab-item {{currentType==1?'active':''}}" bindtap="switchType" data-type="1">收入</view>
    </view>
    <view class="search-row">
      <input
        class="search-input"
        value="{{keyword}}"
        bindinput="inputKeyword"
        placeholder="搜索分类、备注或账本"
      />
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="clearSearch">清空</text>
      <picker mode="date" fields="month" value="{{monthValue}}" bindchange="bindMonthChange">
        <view class="month-btn">{{monthValue}}</view>
      </picker>
    </view>
  </view>

  <!-- 账单列表 -->
  <view class="bill-card">
    <view
      class="bill-item"
      wx:for="{{showList}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="bill-icon">{{item.emoji}}</view>
      <view class="bill-info">
        <view class="bill-title-row">
          <text class="bill-title">{{item.cateName}}</text>
          <text class="book-tag">{{item.bookName || '日常账本'}}</text>
        </view>
        <text class="bill-desc">{{item.remarkText}} · {{item.timeText}}</text>
      </view>
      <view class="bill-right">
        <text class="bill-money {{item.type==0?'expense':'income'}}">{{item.type==0?'-':'+'}}¥{{item.moneyText}}</text>
        <text class="delete-text" catchtap="deleteBill" data-id="{{item.id}}">删除</text>
      </view>
    </view>

    <view class="empty-block" wx:if="{{showList.length==0}}">
      <text class="empty-icon">🧾</text>
      <text class="empty-title">暂无账单记录</text>
      <text class="empty-desc">点击右上角“记一笔”添加账单吧</text>
    </view>
  </view>
</view>
