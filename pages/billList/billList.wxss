/* pages/billList/billList.wxss */
page {
  background: #fff9e8;
}

.page-wrap {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 90rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff9e8 0%, #fff5dc 100%);
}

.summary-card {
  background: linear-gradient(135deg, #ffd66e, #ffad1f);
  border-radius: 32rpx;
  padding: 34rpx 30rpx;
  color: #5a3e0a;
  box-shadow: 0 10rpx 26rpx rgba(255, 176, 31, 0.25);
  margin-bottom: 24rpx;
}

.summary-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.summary-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #5a3e0a;
}

.summary-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  color: rgba(90,62,10,0.75);
}

.add-btn {
  background: rgba(255,255,255,0.72);
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  color: #8a5c00;
}

.summary-grid {
  display: flex;
  margin-top: 30rpx;
  background: rgba(255,255,255,0.34);
  border-radius: 22rpx;
  padding: 22rpx 0;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255,255,255,0.65);
}

.summary-item:last-child {
  border-right: none;
}

.sum-label {
  font-size: 23rpx;
  color: rgba(90,62,10,0.72);
  margin-bottom: 8rpx;
}

.sum-value {
  font-size: 32rpx;
  font-weight: 800;
}

.expense {
  color: #d65a2c;
}

.income {
  color: #2e8b4a;
}

.filter-card,
.bill-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.type-tab {
  display: flex;
  background: #f5efe0;
  border-radius: 999rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #888;
}

.tab-item.active {
  background: #fff;
  color: #222;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-input {
  flex: 1;
  background: #f8f8f8;
  border-radius: 999rpx;
  padding: 18rpx 24rpx;
  min-height: 72rpx;
  box-sizing: border-box;
  font-size: 27rpx;
}

.clear-btn {
  color: #aaa;
  font-size: 24rpx;
}

.month-btn {
  background: #fff7d9;
  color: #b88628;
  border-radius: 999rpx;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
}

.bill-card {
  padding: 8rpx 24rpx;
}

.bill-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5efe0;
}

.bill-item:last-child {
  border-bottom: none;
}

.bill-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff7d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.bill-info {
  flex: 1;
  min-width: 0;
}

.bill-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.bill-title {
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
}

.book-tag {
  font-size: 21rpx;
  color: #b88628;
  background: #fff7d9;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.bill-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #aaa;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bill-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 14rpx;
}

.bill-money {
  font-size: 30rpx;
  font-weight: 800;
}

.delete-text {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
}

.empty-block {
  padding: 90rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #aaa;
}

.empty-icon {
  font-size: 74rpx;
  margin-bottom: 14rpx;
}

.empty-title {
  font-size: 29rpx;
  color: #777;
}

.empty-desc {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
}
