<!--pages/bookManage/bookManage.wxml-->
<view class="page-wrap">

<!-- 统计概览 -->
<view class="stat-row">
  <view class="stat-card">
    <text class="stat-label">账本总数</text>
    <text class="stat-value">{{bookCount}}</text>
  </view>
  <view class="stat-card">
    <text class="stat-label">默认账本</text>
    <text class="stat-value default">{{defaultBookName}}</text>
  </view>
  <view class="stat-card">
    <text class="stat-label">总支出</text>
    <text class="stat-value expense">¥{{totalSpend}}</text>
  </view>
</view>

<!-- 列表头部 -->
<view class="list-head">
  <text class="list-title">我的账本</text>
  <view class="add-book-btn" bindtap="openAddPopup">
    <text>+ 新建账本</text>
  </view>
</view>

<!-- 账本列表 -->
<view class="book-list" wx:if="{{bookList.length > 0}}">
  <view
    class="book-item {{item.isDefault ? 'default-book' : ''}}"
    wx:for="{{bookList}}"
    wx:key="id"
  >
    <view class="book-left">
      <view class="book-icon" style="background:{{item.color}}">
        <text>{{item.icon}}</text>
      </view>
      <view class="book-info">
        <view class="book-name-row">
          <text class="book-name">{{item.name}}</text>
          <text wx:if="{{item.isDefault}}" class="default-tag">默认</text>
        </view>
        <view class="book-meta">
          <text>支出 ¥{{item.totalSpend}}</text>
          <text>收入 ¥{{item.totalIncome}}</text>
          <text>{{item.billCount}} 笔</text>
        </view>
      </view>
    </view>
    <view class="book-right">
      <view class="operate-btn" bindtap="openOperate" data-id="{{item.id}}">
        <text>⋮</text>
      </view>
    </view>
  </view>
</view>

<!-- 空状态 -->
<view class="empty-block" wx:if="{{bookList.length === 0}}">
  <view class="empty-emoji">📒</view>
  <text class="empty-title">还没有账本</text>
  <text class="empty-desc">点击右上角「新建账本」开始分类记账吧~</text>
</view>

<!-- 新建/编辑弹窗 -->
<view wx:if="{{showPopup}}" class="popup-wrap">
  <view class="popup-mask" bindtap="closePopup"></view>
  <view class="popup-box" catchtap="noop">
    <text class="popup-title">{{editId ? '编辑账本' : '新建账本'}}</text>

    <view class="input-wrap">
      <text class="label">账本名称</text>
      <input class="input" placeholder="例：个人日常、家庭共用" bindinput="inputBookName" value="{{tempName}}" maxlength="12" />
    </view>

    <view class="color-wrap">
      <text class="label">选择主题色</text>
      <view class="color-row">
        <view
          class="color-block {{selectColor==item?'active':''}}"
          wx:for="{{colorList}}"
          wx:key="*this"
          style="background:{{item}}"
          bindtap="selectColor"
          data-color="{{item}}"
        ></view>
      </view>
    </view>

    <view class="icon-wrap">
      <text class="label">选择图标</text>
      <view class="icon-row">
        <view
          class="icon-block {{selectIcon==item?'active':''}}"
          wx:for="{{iconList}}"
          wx:key="*this"
          bindtap="selectIcon"
          data-icon="{{item}}"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="check-wrap" bindtap="toggleDefault">
      <view class="checkbox {{isDefault?'checked':''}}">
        <text wx:if="{{isDefault}}">✓</text>
      </view>
      <text>设为默认账本</text>
    </view>

    <view class="popup-btn-row">
      <view class="btn-cancel" bindtap="closePopup">取消</view>
      <view class="btn-sure" bindtap="saveBook">保存</view>
    </view>
  </view>
</view>

<!-- 操作菜单弹窗 -->
<view wx:if="{{showOperatePopup}}" class="popup-wrap">
  <view class="popup-mask" bindtap="closeOperatePopup"></view>
  <view class="operate-popup" catchtap="noop">
    <view class="operate-header">
      <text>{{curOperateName}}</text>
    </view>
    <view class="operate-item" bindtap="setDefault">
      <text>设为默认账本</text>
    </view>
    <view class="operate-item line" bindtap="editBook">
      <text>编辑账本</text>
    </view>
    <view class="operate-item del" bindtap="delBook">
      <text>删除账本</text>
    </view>
    <view class="operate-cancel" bindtap="closeOperatePopup">取消</view>
  </view>
</view>

<!-- 删除确认弹窗 -->
<view wx:if="{{showDeleteConfirm}}" class="popup-wrap">
  <view class="popup-mask" bindtap="closeDeleteConfirm"></view>
  <view class="confirm-box" catchtap="noop">
    <text class="confirm-title">确认删除？</text>
    <text class="confirm-desc">删除后该账本下账单不再归属此账本</text>
    <view class="confirm-btns">
      <view class="btn-cancel" bindtap="closeDeleteConfirm">取消</view>
      <view class="btn-danger" bindtap="confirmDelete">删除</view>
    </view>
  </view>
</view>

</view>
