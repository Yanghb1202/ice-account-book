<!-- pages/classify/classify.wxml -->
<view class="page-wrap">
  <!-- 顶部标题栏 -->
  <view class="top-card">
    <view>
      <text class="page-title">分类管理</text>
      <text class="page-desc">管理记账时使用的支出和收入分类</text>
    </view>
    <view class="add-btn" bindtap="openAddPopup">
      <text>+ 新增</text>
    </view>
  </view>

  <!-- 统计概览 -->
  <view class="stat-row">
    <view class="stat-item">
      <text class="stat-label">支出分类</text>
      <text class="stat-value expense">{{spendTotal}}</text>
    </view>
    <view class="stat-item">
      <text class="stat-label">收入分类</text>
      <text class="stat-value income">{{incomeTotal}}</text>
    </view>
    <view class="stat-item" bindtap="resetDefault">
      <text class="stat-label">默认分类</text>
      <text class="stat-value reset">恢复</text>
    </view>
  </view>

  <!-- 收入/支出标签切换 -->
  <view class="tab-wrap">
    <view class="tab-item {{currentTab==0?'active':''}}" bindtap="switchTab" data-index="0">支出</view>
    <view class="tab-item {{currentTab==1?'active':''}}" bindtap="switchTab" data-index="1">收入</view>
  </view>

  <!-- 分类列表 -->
  <view class="cate-list" wx:if="{{currentTab == 0}}">
    <view
      class="cate-card"
      wx:for="{{spendList}}"
      wx:key="id"
      bindtap="openAction"
      data-id="{{item.id}}"
      data-type="0"
    >
      <view class="cate-icon" style="background:{{item.color}}">
        <text>{{item.icon}}</text>
      </view>
      <view class="cate-info">
        <view class="cate-name-row">
          <text class="cate-name">{{item.name}}</text>
          <text wx:if="{{item.fixed}}" class="fixed-tag">默认</text>
        </view>
        <text class="cate-desc">点击编辑或删除</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view wx:if="{{spendList.length==0}}" class="empty-tip">
      <text class="empty-icon">📦</text>
      <text>暂无支出分类,点击上方新增</text>
    </view>
  </view>

  <view class="cate-list" wx:if="{{currentTab == 1}}">
    <view
      class="cate-card"
      wx:for="{{incomeList}}"
      wx:key="id"
      bindtap="openAction"
      data-id="{{item.id}}"
      data-type="1"
    >
      <view class="cate-icon" style="background:{{item.color}}">
        <text>{{item.icon}}</text>
      </view>
      <view class="cate-info">
        <view class="cate-name-row">
          <text class="cate-name">{{item.name}}</text>
          <text wx:if="{{item.fixed}}" class="fixed-tag">默认</text>
        </view>
        <text class="cate-desc">点击编辑或删除</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view wx:if="{{incomeList.length==0}}" class="empty-tip">
      <text class="empty-icon">📦</text>
      <text>暂无收入分类,点击上方新增</text>
    </view>
  </view>

  <!-- 新增/编辑分类弹窗 -->
  <view wx:if="{{showPopup}}" class="popup-wrap" bindtap="closePopup">
    <view class="popup-box" catchtap="noop">
      <text class="popup-title">{{editId?'编辑分类':'新增分类'}}</text>

      <view class="input-wrap">
        <text class="label">分类名称</text>
        <input
          class="input"
          placeholder="例：餐饮、工资"
          bindinput="inputName"
          value="{{tempName}}"
          maxlength="8"
          adjust-position="true"
        />
      </view>

      <view class="color-wrap">
        <text class="label">选择背景色</text>
        <view class="color-row">
          <view
            class="color-block {{selectColor==item?'active':''}}"
            wx:for="{{colorList}}"
            wx:key="*this"
            style="background:{{item}}"
            bindtap="selectColor"
            data-color="{{item}}"
          ></view>
        </view>
      </view>

      <view class="icon-wrap">
        <text class="label">选择图标</text>
        <view class="icon-row">
          <view
            class="icon-block {{selectIcon==item?'active':''}}"
            wx:for="{{iconList}}"
            wx:key="*this"
            bindtap="selectIcon"
            data-icon="{{item}}"
          >
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <view class="preview-box">
        <view class="preview-icon" style="background:{{selectColor}}">
          <text>{{selectIcon}}</text>
        </view>
        <view>
          <text class="preview-name">{{tempName || '分类预览'}}</text>
          <text class="preview-desc">{{targetTab==0?'支出分类':'收入分类'}}</text>
        </view>
      </view>

      <view class="popup-btn-row">
        <view class="btn-cancel" bindtap="closePopup">取消</view>
        <view class="btn-sure" bindtap="saveCate">保存</view>
      </view>
    </view>
  </view>

  <!-- 操作菜单 -->
  <view wx:if="{{showActionPopup}}" class="popup-wrap">
    <view class="popup-mask" bindtap="closeActionPopup"></view>
    <view class="action-box" catchtap="noop">
      <view class="action-title">{{operateName}}</view>
      <view class="action-item" bindtap="editCate">编辑分类</view>
      <view class="action-item delete" bindtap="askDeleteCate">删除分类</view>
      <view class="action-cancel" bindtap="closeActionPopup">取消</view>
    </view>
  </view>

  <!-- 删除确认 -->
  <view wx:if="{{showDeleteConfirm}}" class="popup-wrap">
    <view class="popup-mask" bindtap="closeDeleteConfirm"></view>
    <view class="confirm-box" catchtap="noop">
      <text class="confirm-title">确认删除？</text>
      <text class="confirm-desc">删除后不会影响已有账单,只是以后不能再选择这个分类。</text>
      <view class="confirm-btns">
        <view class="btn-cancel" bindtap="closeDeleteConfirm">取消</view>
        <view class="btn-danger" bindtap="confirmDeleteCate">删除</view>
      </view>
    </view>
  </view>
</view>
