page {
  background-color: #f6f5f1;
  margin: 0;
  padding: 0;
}
.page-wrap {
  width: 100%;
  min-height: 100vh;
  padding: 20rpx 30rpx 160rpx;
  box-sizing: border-box;
  background: #f6f5f1;
}

/* ==================== 顶部区域 ==================== */
.top-area {
  margin-bottom: 20rpx;
}

.logo-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0 20rpx;
}
.logo-text {
  font-size: 48rpx;
  font-weight: 900;
  color: #222;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  letter-spacing: -2rpx;
}
.back-btn {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 20rpx;
  background: #fff;
  border-radius: 30rpx;
}

/* 星期选择栏 */
.week-bar {
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
}
.week-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.week-text {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.week-item {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e8e6e1;
  transition: all 0.2s;
}
.week-item.active {
  background: #fff;
  border: 3rpx solid #222;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.day-num {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.week-item.active .day-num {
  color: #222;
  font-weight: 600;
}

/* ==================== 手账卡片 ==================== */
.note-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx 40rpx 60rpx;
  min-height: 800rpx;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

/* 左侧装订孔 */
.hole-list {
  position: absolute;
  left: 18rpx;
  top: 60rpx;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: calc(100% - 120rpx);
}
.hole {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e0ddd6;
}

/* 总热量 */
.cal-top {
  margin-bottom: 30rpx;
}
.cal-title {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}
.cal-num-wrap {
  display: flex;
  align-items: baseline;
}
.cal-num {
  font-size: 72rpx;
  font-weight: bold;
  color: #222;
  line-height: 1;
}
.cal-limit {
  font-size: 32rpx;
  color: #bbb;
  margin-left: 10rpx;
}

/* 贴纸区域 */
.sticker-area {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx;
  padding: 20rpx 0;
}

/* 食物贴纸 */
.food-sticker {
  width: 260rpx;
  position: relative;
}
.sticker-bg {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: 8rpx;
  bottom: 8rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx dashed #ddd;
  transform: rotate(-2deg);
  z-index: 1;
}
.sticker-img {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}
.sticker-placeholder {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  position: relative;
  z-index: 2;
}
.sticker-desc {
  position: relative;
  z-index: 2;
  margin-top: 12rpx;
  padding-left: 4rpx;
}
.food-name {
  display: block;
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
}
.food-cal {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 200rpx 0;
}
.empty-tip text {
  display: block;
  font-size: 30rpx;
  color: #bbb;
  line-height: 1.8;
}

/* ==================== AI弹窗 - 全屏浅色 ==================== */
.ai-popup-page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #f0eeea;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

/* 背景横线装饰 */
.popup-line-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 60rpx,
    rgba(0,0,0,0.03) 60rpx,
    rgba(0,0,0,0.03) 61rpx
  );
  pointer-events: none;
}

/* 预览贴纸 */
.preview-sticker {
  width: 360rpx;
  height: 360rpx;
  position: relative;
  margin-bottom: 40rpx;
}
.preview-sticker-bg {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: 10rpx;
  bottom: 10rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx dashed #ccc;
  transform: rotate(-3deg);
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}
.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.12);
}

/* 食物名称 */
.food-name-txt {
  font-size: 48rpx;
  color: #222;
  font-weight: 600;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 2;
}

/* AI介绍 */
.ai-title {
  text-align: center;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 2;
}
.ai-title text {
  display: block;
  font-size: 30rpx;
  color: #666;
  line-height: 1.6;
}

/* 加载中 */
.loading-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 30rpx;
  position: relative;
  z-index: 2;
}
.spark {
  color: #ffc837;
  font-size: 32rpx;
  margin-right: 12rpx;
}
.loading-pill text:last-child {
  font-size: 28rpx;
  color: #999;
}

/* AI信息卡片 */
.ai-info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 40rpx;
  width: 80%;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 30rpx;
  position: relative;
  z-index: 2;
}
.info-text {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

/* 候选菜品 */
.candidate-box {
  width: 80%;
  margin: 0 0 24rpx;
  position: relative;
  z-index: 2;
}
.candidate-title {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 14rpx;
  text-align: center;
}
.candidate-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}
.candidate-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #666;
  font-size: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.candidate-item.active {
  background: #222;
  color: #fff;
}

/* 价格输入 */
.price-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  width: 70%;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 40rpx;
  position: relative;
  z-index: 2;
}
.price-label {
  font-size: 36rpx;
  color: #222;
  font-weight: 600;
  margin-right: 12rpx;
}
.price-input {
  flex: 1;
  font-size: 32rpx;
  color: #222;
}

/* 底部按钮 */
.popup-btn-row {
  display: flex;
  align-items: center;
  gap: 40rpx;
  position: relative;
  z-index: 2;
}
.btn-cancel, .btn-edit {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #222;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.btn-sure {
  width: 140rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #222;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

/* ==================== 底部导航栏 ==================== */
.bottom-btn-bar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.04);
  z-index: 100;
}
.bottom-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}
.active-dot {
  background: #222;
}
.grid-icon {
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
}
.btn-add {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #222;
  color: #fff;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}
