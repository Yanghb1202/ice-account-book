/* pages/feedback/feedback.wxss */
page {
  background: #fff9e8;
}

.page-wrap {
  width: 100%;
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 2%, rgba(255, 214, 110, 0.35), transparent 220rpx),
    linear-gradient(180deg, #fff9e8 0%, #fff5dc 100%);
}

/* 顶部 */
.top-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #ffe8a8, #ffd166);
  border-radius: 32rpx;
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(255, 190, 60, 0.20);
}

.top-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  flex-shrink: 0;
}

.top-text {
  flex: 1;
}

.title-text {
  font-size: 42rpx;
  font-weight: 800;
  color: #5a3e0a;
  display: block;
  margin-bottom: 8rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #8a6a1f;
}

/* 联系卡片 */
.contact-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04);
}

.contact-title {
  display: block;
  font-size: 28rpx;
  color: #222;
  font-weight: 600;
}

.contact-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.contact-action {
  color: #d99a13;
  font-size: 26rpx;
}

/* 通用卡片 */
.card-box {
  background: #fff;
  border-radius: 30rpx;
  padding: 32rpx 30rpx;
  margin-bottom: 26rpx;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.045);
}

.card-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.card-head.between {
  justify-content: space-between;
}

.head-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.head-icon {
  width: 60rpx;
  height: 60rpx;
  background: #fff2bf;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.head-text {
  font-size: 34rpx;
  color: #222;
  font-weight: 700;
}

/* FAQ */
.faq-item {
  border-bottom: 1rpx solid #f5efe0;
  padding: 26rpx 0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #222;
  font-weight: 500;
}

.arrow {
  font-size: 38rpx;
  color: #bbb;
  transition: transform 0.25s;
}

.arrow.rotate {
  transform: rotate(90deg);
}

.faq-a {
  margin-top: 18rpx;
  font-size: 27rpx;
  color: #666;
  line-height: 1.7;
  background: #fff8e4;
  padding: 20rpx;
  border-radius: 18rpx;
}

/* 表单 */
.label {
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.optional {
  color: #aaa;
  font-weight: 400;
  font-size: 24rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.word-num {
  font-size: 24rpx;
  color: #aaa;
}

.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 34rpx;
}

.type-item {
  width: calc((100% - 16rpx) / 2);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 0;
  background: #f8f8f8;
  border-radius: 18rpx;
  font-size: 27rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #fff7d9;
  color: #c08010;
  border-color: #ffc837;
  font-weight: 600;
}

.type-icon {
  font-size: 30rpx;
}

.input-wrap,
.upload-wrap {
  margin-bottom: 34rpx;
}

.text-area {
  width: 100%;
  min-height: 220rpx;
  background: #f8f8f8;
  border-radius: 22rpx;
  padding: 26rpx;
  font-size: 29rpx;
  box-sizing: border-box;
  line-height: 1.6;
  color: #333;
}

.input {
  width: 100%;
  background: #f8f8f8;
  border-radius: 22rpx;
  padding: 28rpx 26rpx;
  min-height: 92rpx;
  font-size: 29rpx;
  box-sizing: border-box;
  color: #333;
}

.placeholder {
  color: #bbb;
}

/* 图片 */
.img-row {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.img-item,
.upload-add {
  width: 148rpx;
  height: 148rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  background: #f8f8f8;
}

.img-item image {
  width: 100%;
  height: 100%;
}

.upload-add {
  border: 2rpx dashed #e7d6a8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 42rpx;
  color: #c9a85a;
}

.upload-tip {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 6rpx;
}

.del-img {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 38rpx;
  height: 38rpx;
  background: rgba(0,0,0,0.45);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 38rpx;
  font-size: 26rpx;
}

/* 按钮 */
.submit-btn {
  width: 100%;
  text-align: center;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #ffd66e, #ffad1f);
  color: #fff;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(255, 176, 31, 0.22);
}

/* 历史 */
.clear-btn {
  color: #aaa;
  font-size: 25rpx;
}

.history-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f5efe0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.history-type {
  font-size: 27rpx;
  color: #222;
  font-weight: 600;
}

.history-status {
  font-size: 23rpx;
  color: #2e8b4a;
  background: #e9f8ee;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.history-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.55;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #aaa;
}

/* 成功弹窗 */
.pop-wrap {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.38);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pop-box {
  width: 78%;
  background: #fff;
  border-radius: 36rpx;
  padding: 54rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.pop-icon {
  font-size: 78rpx;
  margin-bottom: 20rpx;
}

.pop-title {
  font-size: 38rpx;
  color: #222;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.pop-desc {
  font-size: 28rpx;
  color: #777;
}

.pop-time {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
  margin-bottom: 36rpx;
}

.pop-btn {
  width: 100%;
  text-align: center;
  padding: 26rpx 0;
  background: #ffc837;
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
}
