/* pages/index/index.wxss */
page {
  background: #fff9e8;
}

.page-wrap {
  width: 100%;
  min-height: 100vh;
  padding: 36rpx 28rpx 180rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 214, 110, 0.35), transparent 220rpx),
    linear-gradient(180deg, #fff9e8 0%, #fff5dc 100%);
}

/* 顶部欢迎 */
.header-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.hello-text {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.3;
}
.sub-text {
  display: block;
  font-size: 26rpx;
  color: #9a7b2f;
  margin-top: 8rpx;
}
.avatar-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
}

/* 本月收支主卡 */
.money-card {
  background: linear-gradient(135deg, #ffd66e 0%, #ffb22a 100%);
  border-radius: 32rpx;
  padding: 34rpx 30rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(255, 184, 42, 0.28);
  color: #5a3e0a;
}
.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.card-label {
  display: block;
  font-size: 26rpx;
  color: rgba(90,62,10,0.75);
}
.pay-row {
  display: flex;
  align-items: flex-end;
  margin-top: 8rpx;
}
.money-symbol {
  font-size: 42rpx;
  font-weight: 700;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}
.pay-num {
  font-size: 70rpx;
  font-weight: 800;
  line-height: 1;
  max-width: 470rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}
.detail-btn {
  background: rgba(255,255,255,0.72);
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #8a5c00;
}
.money-grid {
  display: flex;
  margin-top: 34rpx;
  background: rgba(255,255,255,0.34);
  border-radius: 22rpx;
  padding: 22rpx 0;
}
.money-grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255,255,255,0.65);
  min-width: 0;
}
.money-grid-item:last-child {
  border-right: none;
}
.grid-label {
  font-size: 22rpx;
  color: rgba(90,62,10,0.7);
  margin-bottom: 8rpx;
}
.grid-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #5a3e0a;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.grid-value.income {
  color: #2e8b4a;
}

/* 今日概览 */
.today-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 22rpx;
}
.today-card {
  flex: 1;
  background: #fff;
  border-radius: 22rpx;
  padding: 22rpx 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04);
  min-width: 0;
}
.today-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.today-value {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.today-value.expense {
  color: #d65a2c;
}
.today-value.income {
  color: #2e8b4a;
}

/* 通用卡片 */
.section-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}
.section-more {
  font-size: 24rpx;
  color: #aaa;
}

/* 功能入口 */
.func-row {
  display: flex;
  justify-content: space-between;
}
.func-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.func-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 24rpx;
  background: #fff7d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}
.func-name {
  font-size: 25rpx;
  color: #333;
  font-weight: 600;
}
.func-desc {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 4rpx;
}

/* 预算 */
.budget-card {
  background: linear-gradient(180deg, #ffffff 0%, #fffaf0 100%);
}
.budget-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.budget-main {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}
.budget-desc {
  display: block;
  font-size: 23rpx;
  color: #999;
  margin-top: 8rpx;
}
.budget-percent {
  font-size: 34rpx;
  font-weight: 800;
  color: #ffad1f;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 14rpx;
  background: #f1ead8;
  border-radius: 999rpx;
  position: relative;
  overflow: hidden;
}
.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #ffd66e, #ffad1f);
  border-radius: 999rpx;
  transition: width 0.25s;
}
.budget-inner {
  background: linear-gradient(90deg, #91dc9d, #2e8b4a);
}
.progress-text {
  position: absolute;
  right: 0;
  top: -38rpx;
  font-size: 23rpx;
  color: #999;
}

/* 存钱挑战 */
.save-content {
  display: flex;
  align-items: center;
}
.save-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #fff7d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 22rpx;
  flex-shrink: 0;
}
.save-info {
  flex: 1;
  min-width: 0;
}
.plan-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}
.plan-desc {
  display: block;
  color: #888;
  font-size: 24rpx;
  margin: 8rpx 0 18rpx;
}

/* 账单列表 */
.bill-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5efe0;
}
.bill-item:last-child {
  border-bottom: none;
}
.bill-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #fff7d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}
.bill-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.bill-name {
  font-size: 29rpx;
  color: #222;
  font-weight: 600;
}
.bill-desc {
  font-size: 23rpx;
  color: #aaa;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bill-money {
  font-size: 30rpx;
  font-weight: 700;
  margin-left: 16rpx;
}
.bill-money.expense {
  color: #d65a2c;
}
.bill-money.income {
  color: #2e8b4a;
}
.empty-bill-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 46rpx 0;
}
.empty-emoji {
  font-size: 72rpx;
  opacity: 0.65;
  margin-bottom: 12rpx;
}
.empty-title {
  font-size: 28rpx;
  color: #666;
}
.empty-desc {
  font-size: 23rpx;
  color: #aaa;
  margin-top: 8rpx;
}


