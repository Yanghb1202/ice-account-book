/* pages/login/login.wxss */
page {
  background: #fff9e8;
}

.page-wrap {
  min-height: 100vh;
  padding: 90rpx 32rpx 80rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 3%, rgba(255, 214, 110, 0.36), transparent 230rpx),
    linear-gradient(180deg, #fff9e8 0%, #fff5dc 100%);
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 52rpx;
}

.logo-box {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffe8a8, #ffd166);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 82rpx;
  box-shadow: 0 8rpx 22rpx rgba(255, 190, 60, 0.22);
}

.title {
  font-size: 54rpx;
  font-weight: 800;
  color: #222;
  margin-top: 24rpx;
}

.subtitle {
  font-size: 27rpx;
  color: #9a7b2f;
  margin-top: 8rpx;
}

.form-card {
  background: #fff;
  border-radius: 34rpx;
  padding: 40rpx 32rpx 42rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
}

.account-tip {
  background: #fff7d9;
  color: #b88628;
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  font-size: 25rpx;
  margin-bottom: 28rpx;
}

.input-item {
  height: 98rpx;
  background: #f8f8f8;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.input {
  flex: 1;
  height: 100%;
  font-size: 29rpx;
  color: #333;
}

.eye-btn {
  font-size: 24rpx;
  color: #b88628;
  margin-left: 12rpx;
}

.tool-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 6rpx 0 34rpx;
  font-size: 25rpx;
  color: #888;
}

.remember-box {
  display: flex;
  align-items: center;
}

.check-box {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  color: #fff;
  font-size: 22rpx;
}

.check-box.checked {
  background: #ffc837;
  border-color: #ffc837;
}

.forget-text {
  color: #d99a13;
}

.main-btn {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffd66e, #ffad1f);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(255, 176, 31, 0.25);
}

.main-btn::after {
  border: none;
}

.demo-btn {
  width: 100%;
  text-align: center;
  padding: 26rpx 0;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #fff7d9;
  color: #b88628;
  font-size: 29rpx;
  font-weight: 600;
}

.bottom-link {
  margin-top: 34rpx;
  text-align: center;
  font-size: 27rpx;
  color: #888;
}

.link-text {
  color: #d99a13;
  font-weight: 700;
}
