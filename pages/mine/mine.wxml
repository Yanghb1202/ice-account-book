<view class="page-wrap">
  <view class="hero-card">
    <view class="hero-bg-circle one"></view>
    <view class="hero-bg-circle two"></view>

    <view class="top-row">
      <view class="page-title">
        <text class="title-main">我的</text>
        <text class="title-sub">记录每一笔，也记录更好的生活</text>
      </view>
      <view class="set-btn" bindtap="goSetPage">
        <text>⚙️</text>
      </view>
    </view>

    <view wx:if="{{!isLogin}}" class="login-panel">
      <view class="avatar-placeholder">
        <text>👋</text>
      </view>
      <view class="login-text">
        <text class="login-title">欢迎来到记账小窝</text>
        <text class="login-desc">登录后同步查看资产、预算和账本管理</text>
      </view>
      <view class="login-actions">
        <button class="login-btn" bindtap="goLogin">登录</button>
        <button class="register-btn" bindtap="goRegister">注册</button>
      </view>
    </view>

    <view wx:else class="user-info-box">
      <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" bindtap="handleAvatarClick"></image>
      <view class="user-text">
        <text class="user-name">{{userInfo.nickname}}</text>
        <text class="user-tip">UID {{userInfo.uid || '未设置'}} · 点击头像更换</text>
      </view>
    </view>
  </view>

  <view class="asset-card">
    <view class="asset-header">
      <view>
        <text class="asset-title">我的资产</text>
        <text class="asset-date">{{currentMonthText}}</text>
      </view>
      <view class="asset-tag">自动统计</view>
    </view>

    <view class="asset-main">
      <text class="currency">¥</text>
      <text class="asset-num">{{assetTotal}}</text>
    </view>

    <view class="asset-row">
      <view class="asset-item income">
        <text class="label">累计收入</text>
        <text class="val">¥{{asset}}</text>
      </view>
      <view class="asset-item debt">
        <text class="label">当前负债</text>
        <text class="val">¥{{debt}}</text>
      </view>
    </view>
  </view>

  <view class="month-card">
    <view class="month-item">
      <text class="month-label">本月收入</text>
      <text class="month-val plus">¥{{monthIncome}}</text>
    </view>
    <view class="month-line"></view>
    <view class="month-item">
      <text class="month-label">本月支出</text>
      <text class="month-val minus">¥{{monthExpense}}</text>
    </view>
    <view class="month-line"></view>
    <view class="month-item">
      <text class="month-label">账单数</text>
      <text class="month-val">{{billCount}}笔</text>
    </view>
  </view>

  <view class="quick-grid">
    <view class="quick-item" wx:for="{{quickList}}" wx:key="type" bindtap="checkLoginJump" data-type="{{item.type}}">
      <view class="quick-icon">{{item.icon}}</view>
      <text class="quick-title">{{item.title}}</text>
      <text class="quick-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="menu-group" wx:for="{{menuGroups}}" wx:key="title">
    <text class="group-title">{{item.title}}</text>
    <view class="menu-box">
      <view
        class="menu-item"
        wx:for="{{item.list}}"
        wx:for-item="menu"
        wx:key="type"
        bindtap="checkLoginJump"
        data-type="{{menu.type}}"
      >
        <view class="menu-icon {{menu.iconClass}}">
          <text>{{menu.icon}}</text>
        </view>
        <view class="menu-text-wrap">
          <text class="menu-text">{{menu.text}}</text>
          <text class="menu-sub">{{menu.sub}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="bottom-actions">
    <view class="action-btn" bindtap="clearLocalCache">清理缓存</view>
    <view class="action-btn logout" bindtap="logout">{{isLogin ? '退出登录' : '去登录'}}</view>
  </view>
</view>
