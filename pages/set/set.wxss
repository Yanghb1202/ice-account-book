/* pages/set/set.wxss */
page {
  background: #fff8e6;
  margin: 0;
  padding: 0;
}

.page-wrap {
  width: 100%;
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 20% 4%, rgba(255, 214, 110, 0.35), transparent 220rpx),
    linear-gradient(180deg, #fff9e8 0%, #fff5dc 100%);
}

/* 顶部卡片 */
.top-card {
  background: linear-gradient(135deg, #ffe8a8, #ffd166);
  border-radius: 30rpx;
  padding: 34rpx 30rpx;
  margin-bottom: 26rpx;
  box-shadow: 0 8rpx 22rpx rgba(255, 190, 60, 0.20);
}

.card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.head-icon {
  width: 76rpx;
  height: 76rpx;
  background: rgba(255,255,255,0.72);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.head-title {
  font-size: 40rpx;
  color: #5a3e0a;
  font-weight: 800;
  display: block;
}

.desc-txt {
  font-size: 26rpx;
  color: #8a6a1f;
  display: block;
  margin-top: 8rpx;
}

.cache-row {
  display: flex;
  background: rgba(255,255,255,0.45);
  border-radius: 20rpx;
  padding: 18rpx 0;
}

.cache-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255,255,255,0.65);
}

.cache-item:last-child {
  border-right: none;
}

.cache-label {
  font-size: 22rpx;
  color: #8a6a1f;
  margin-bottom: 6rpx;
}

.cache-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #5a3e0a;
}

/* 分组标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #8a6a1f;
  margin: 28rpx 8rpx 14rpx;
}

/* 设置列表卡片 */
.list-card {
  background: #fff;
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.045);
}

.set-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f0e1;
}

.set-item:last-child {
  border-bottom: none;
}

.set-item.danger-light {
  background: #fffafa;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.item-icon {
  width: 58rpx;
  height: 58rpx;
  background: #fff7d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.item-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  display: block;
}

.item-desc {
  font-size: 23rpx;
  color: #aaa;
  display: block;
  margin-top: 6rpx;
  line-height: 1.35;
}

.right-arrow {
  font-size: 34rpx;
  color: #ccc;
  margin-left: 16rpx;
}

switch {
  transform: scale(0.82);
}

/* 退出登录区域 */
.logout-wrap {
  width: 100%;
  margin-top: 44rpx;
}

.logout-btn {
  width: 100%;
  text-align: center;
  padding: 28rpx 0;
  background: #ff6b6b;
  color: #fff;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 107, 0.18);
}

/* 底部版权 */
.copyright {
  text-align: center;
  padding: 44rpx 0 0;
  font-size: 24rpx;
  color: #aaa;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.copyright-sub {
  color: #c0a86a;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.38);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 80%;
  background: #fff;
  border-radius: 34rpx;
  padding: 50rpx 38rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.modal-icon {
  font-size: 76rpx;
  margin-bottom: 22rpx;
}

.modal-title {
  font-size: 38rpx;
  color: #222;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #777;
  text-align: center;
  line-height: 1.65;
  margin-bottom: 42rpx;
}

.btn-row {
  display: flex;
  gap: 22rpx;
  width: 100%;
}

.btn-cancel,
.btn-confirm,
.single-btn {
  text-align: center;
  padding: 26rpx 0;
  border-radius: 999rpx;
  font-size: 32rpx;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #555;
}

.btn-confirm {
  flex: 1;
  background: #ffd166;
  color: #fff;
}

.single-btn {
  width: 100%;
  background: #ffd166;
  color: #fff;
}
